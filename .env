###> symfony/framework-bundle ###
APP_ENV=dev
# Dev-only dummy. Override with a real secret in .env.local for production
# (see .env.local.example). Never use this value outside local development.
APP_SECRET=dev-only-dummy-secret-not-for-production
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

DATABASE_URL="sqlite:///%kernel.project_dir%/data/app.db"
AI_KEY=

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
