# Production environment template.
#
# Copy this to .env.local on the server and fill in real values:
#     cp .env.local.example .env.local
#
# Symfony loads .env.local AFTER .env, so the values here override the committed
# dev defaults in .env. docker-compose intentionally does NOT set these as
# container environment variables, because real env vars would take precedence
# over this file. This file is the single source of truth for production config.

# Run the app in production mode (disables debug, uses the optimized cache).
APP_ENV=prod

# Generate a real secret, e.g.:
#     php -r "echo bin2hex(random_bytes(16)).PHP_EOL;"
APP_SECRET=change-me

# SQLite index. Keep it on a persisted volume (./data is bind-mounted).
DATABASE_URL="sqlite:///%kernel.project_dir%/data/app.db"

# Optional: enables semantic/embedding search during `app:sync`. Leave empty to
# fall back to plain full-text search.
AI_KEY=
