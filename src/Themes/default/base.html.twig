<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#03050a">
    <meta name="description" content="{% block description %}hcnotes — web developer, gamer, father.{% endblock %}">
    <title>{% block title %}HCNOTES{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="{{ asset_v('/assets/css/dedsec.css') }}" rel="stylesheet">
</head>
<body>
    <canvas id="aleph-bg" aria-hidden="true"></canvas>
    <div class="fx-overlay scanlines" aria-hidden="true"></div>
    <div class="fx-overlay flicker" aria-hidden="true"></div>
    <div class="fx-overlay vignette" aria-hidden="true"></div>

    <nav class="nav">
        <a href="/" class="nav__brand">HCNOTES</a>
        <div class="nav__links">
            <a href="/about">About</a>
            <a href="https://github.com/matasarei" target="_blank" rel="noopener">GitHub</a>
        </div>
    </nav>

    <div class="shell">
        {% block content %}{% endblock %}
    </div>

    <script src="{{ asset_v('/assets/js/aleph.js') }}" defer></script>
    {% block scripts %}{% endblock %}
</body>
</html>
